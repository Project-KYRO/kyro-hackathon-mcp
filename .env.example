# KYRO Hackathon MCP — env reference. Copy to .env.local and fill.

# Supabase prod — service role for SECURITY DEFINER RPC calls
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# PAT hash — server-side secret (must match across vercel + admin script)
# Generate: openssl rand -base64 32
PAT_HASH_PEPPER=

# Token expiry — when all hackathon PATs auto-expire (ISO 8601)
HACKATHON_PAT_EXPIRES_AT=2026-05-11T20:00:00+09:00

# Public base URL of this deployment
NEXT_PUBLIC_BASE_URL=https://kyro-hackathon-mcp.vercel.app
