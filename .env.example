# KYRO Hackathon MCP — env reference. Copy to .env.local and fill.
# All from Supabase prod project (zkjpqbhmsvbibygemqfb.supabase.co).

# Supabase prod — service role used for SECURITY DEFINER RPC calls
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — transactional email for OTP delivery
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=KYRO Hackathon <hackathon@your-verified-domain.com>

# Upstash Redis — OTP storage + rate limit (Vercel KV alternative; same REST API)
# https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PAT issuance — server-side secret used to derive token_hash from raw token
# Generate: openssl rand -base64 32
PAT_HASH_PEPPER=

# Token expiry — when all hackathon PATs auto-expire (ISO 8601)
HACKATHON_PAT_EXPIRES_AT=2026-05-11T20:00:00+09:00

# Public base URL of this deployment (for MCP config snippet in token reveal page)
NEXT_PUBLIC_BASE_URL=https://kyro-hackathon-mcp.vercel.app
